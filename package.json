{
  "name": "food-ordering-system",
  "version": "1.8.0",
  "description": "سیستم رزرو و سفارش غذا",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "stop": "node backend/scripts/stop-server.js",
    "restart": "npm run stop && npm start",
    "dev": "nodemon backend/server.js",
    "vendor:sync": "node backend/scripts/sync-vendor.js",
    "build:client": "node backend/scripts/build-client-js.js",
    "build:spa": "cd frontend && npm install && npm run build",
    "seed:portal-slides": "node backend/scripts/download-portal-slide-images.js",
    "build": "npm run build:client && npm run build:spa",
    "postinstall": "node backend/scripts/sync-vendor.js",
    "test:outage": "node backend/scripts/test-db-outage.js",
    "docker:up": "docker compose --env-file .env.docker up -d --build",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f --tail=200",
    "docker:scale": "docker compose --env-file .env.docker up -d --scale app=2 --no-recreate"
  },
  "keywords": [
    "food",
    "ordering",
    "reservation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@majidh1/jalalidatepicker": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.0",
    "firewtwall": "^2.4.7",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "ldapts": "^8.1.8",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "sweetalert2": "^11.26.25",
    "vazirmatn": "^33.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
