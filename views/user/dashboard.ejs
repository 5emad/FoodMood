<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/session-security') %>
  <title>پرتال تغذیه سازمانی</title>
  <%- include('../partials/head-assets', { includeSweetAlert: false }) %>
  <link rel="stylesheet" href="/css/enterprise-theme.css">
  <link rel="stylesheet" href="/css/theme-vars.css">
  <%- include('../partials/app-base-meta') %>
  <script src="<%= jsAsset('app-base') %>" defer></script>
  <script src="<%= jsAsset('security') %>" defer></script>
</head>
<body>
<div id="toast-container"></div>

<!-- No active week overlay -->
<div id="noWeekOverlay" class="glass-overlay" style="display:none">
  <div class="glass-box sm">
    <div style="font-size:3rem;margin-bottom:16px;color:var(--primary-light)"><i class="fas fa-hourglass-half"></i></div>
    <div class="modal-title">برنامه فعال نیست</div>
    <div class="modal-desc">در حال حاضر منوی فعالی وجود ندارد.<br>لطفاً بعداً مراجعه فرمایید.</div>
    <a href="/logout" class="btn btn-danger btn-w100" style="text-decoration:none;justify-content:center;padding:12px;">
      <i class="fas fa-power-off"></i> خروج از سیستم
    </a>
  </div>
</div>

<!-- Top Nav -->
<nav class="top-nav">
  <div class="nav-brand">
    <div class="nav-brand-icon"><i class="fas fa-utensils"></i></div>
    <div>
      <div class="nav-brand-title">اتوماسیون تغذیه</div>
      <span class="nav-brand-sub">پرتال کارکنان</span>
    </div>
  </div>
  <div class="nav-user">
    <div class="nav-user-info">
      <span class="nav-u-name" id="userName">همکار گرامی</span>
      <span class="nav-u-dept" id="userDept">واحد عمومی</span>
    </div>
    <a href="/logout" class="btn-icon logout-btn" title="خروج"><i class="fas fa-power-off"></i></a>
  </div>
</nav>

<main class="user-portal-shell">

  <div class="user-portal-main">

  <!-- Page Header -->
  <div class="page-header" style="margin-bottom:28px">
    <div>
      <div class="ph-badge"><i class="fas fa-calendar-week"></i> هفته جاری</div>
      <div class="ph-title">برنامه غذایی هفته</div>
      <div class="ph-sub" id="weekTitle">در حال بارگذاری برنامه فعال...</div>
    </div>
    <i class="fas fa-bowl-food ph-icon"></i>
  </div>

  <!-- Tabs -->
  <div class="user-tabs">
    <button class="tab-button active" data-tab="menu">
      <i class="fas fa-calendar-days"></i> منوی هفته
    </button>
    <button class="tab-button" data-tab="orders">
      <i class="fas fa-receipt"></i> سفارش‌های من
    </button>
    <button class="tab-button" data-tab="statement" id="statementTabBtn">
      <i class="fas fa-file-invoice-dollar"></i> صورتحساب
    </button>
  </div>

  <!-- Menu Tab -->
  <section id="tab-menu" class="tab-panel active">
    <div class="menu-grid" id="menuGrid">
      <div style="padding:40px;text-align:center"><div class="spinner"></div></div>
    </div>
  </section>

  <!-- Orders Tab -->
  <section id="tab-orders" class="tab-panel">
    <div class="table-wrap" id="ordersWrap">
      <div style="padding:40px;text-align:center"><div class="spinner"></div></div>
    </div>
  </section>

  <!-- Statement Tab -->
  <section id="tab-statement" class="tab-panel">
    <div class="section-header" style="margin-bottom:18px">
      <div>
        <div class="section-title">صورتحساب مالی</div>
        <div class="section-sub" id="statementSubtitle">صورت حساب ارسال شده به حسابداری</div>
      </div>
    </div>
    <div class="statement-controls">
      <div class="sub-tabs">
        <button class="sub-tab-btn active" data-stmt-sub="weekly" id="stmtSubWeekly"><i class="fas fa-calendar-week"></i> هفتگی</button>
        <button class="sub-tab-btn" data-stmt-sub="monthly" id="stmtSubMonthly"><i class="fas fa-calendar"></i> ماهیانه</button>
      </div>
    </div>
    <div class="statement-split-banner" id="statementSplitBanner"></div>
    <div class="table-wrap" id="statementTableWrap">
      <div style="padding:40px;text-align:center"><div class="spinner"></div></div>
    </div>
  </section>

  </div>

</main>

<!-- اطلاعیه — بعد از main و قبل از اسکریپت -->
<div id="announcementsUi" class="announcements-ui" hidden>
  <button type="button" class="ann-fab" id="announcementsTrigger" aria-label="مشاهده اطلاعیه‌ها">
    <i class="fas fa-bullhorn"></i>
    <span class="ann-fab-label">اطلاعیه</span>
    <span class="ann-fab-count" id="announcementsCount"></span>
  </button>

  <div class="ann-drawer-overlay" id="announcementsOverlay" hidden></div>
  <div class="ann-drawer" id="announcementsDrawer" aria-hidden="true" role="dialog" aria-labelledby="announcementsDrawerTitle">
    <div class="ann-drawer-handle" aria-hidden="true"></div>
    <div class="ann-drawer-header">
      <div class="ann-drawer-title" id="announcementsDrawerTitle">
        <i class="fas fa-bullhorn"></i>
        <span>اطلاعیه‌های فعال</span>
      </div>
      <button type="button" class="btn-icon ann-drawer-close" id="announcementsClose" aria-label="بستن">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="ann-drawer-body" id="announcementsList"></div>
  </div>
</div>

<script src="<%= jsAsset('portal-capabilities') %>"></script>
<script type="application/json" id="user-portal-bootstrap"><%- safeJsonForHtml({
  capabilities: typeof capabilities !== 'undefined' ? capabilities : null,
  portalSettings: typeof portalSettings !== 'undefined' ? portalSettings : {
    showFinancialStatementToUsers: true,
    organizationSharePercent: 50,
    personalSharePercent: 50,
    showPricesToUsers: true,
  }
}) %></script>

<script>
const userPortalBoot = (() => {
  const el = document.getElementById('user-portal-bootstrap');
  try { return el ? JSON.parse(el.textContent || '{}') : {}; } catch { return {}; }
})();

function resolveCapabilities() {
  const Caps = window.PortalCapabilities;
  const raw = Object.assign({}, userPortalBoot.portalSettings || {}, userPortalBoot.capabilities || {});
  return Caps ? Caps.normalizeUserCapabilities(raw) : {
    showPrices: raw.showPrices !== false && raw.showPricesToUsers !== false,
    showStatement: raw.showStatement !== false && raw.showFinancialStatementToUsers !== false,
    organizationSharePercent: Number(raw.organizationSharePercent || 50),
    personalSharePercent: Number(raw.personalSharePercent || 50),
    statementDisabledMessage: 'در حال حاضر در دسترس نیست',
  };
}

let caps = resolveCapabilities();
let ordersCache = [];
let menuCache = null;
let showPricesToUsers = caps.showPrices;
let showFinancialStatementToUsers = caps.showStatement;
let defaultMenuItemCapacity = 20;
let statementSubTab = 'weekly';
let statementSplitConfig = {
  organizationSharePercent: Number(caps.organizationSharePercent || 50),
  personalSharePercent: Number(caps.personalSharePercent || 50),
};
const pendingMenuItems = new Set();

function applyCapabilities(next) {
  caps = Object.assign({}, caps, next || {});
  showPricesToUsers = caps.showPrices !== false;
  showFinancialStatementToUsers = caps.showStatement !== false;
  statementSplitConfig = {
    organizationSharePercent: Number(caps.organizationSharePercent || 0),
    personalSharePercent: Number(caps.personalSharePercent || 0),
  };
  if (window.PortalCapabilities) window.PortalCapabilities.applyUserPortalTabs(caps);
  else syncStatementTabVisibility();
}

function api(url, options = {}) {
  return fetch(url, {
    ...options,
    credentials: 'same-origin',
    headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
  }).then(async r => {
    if (r.status === 401) { window.location.replace('/login?expired=1'); throw new Error('401'); }
    return r.json();
  });
}

function toast(message, type = 'success') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  const icons = { success: 'check-circle', error: 'exclamation-circle', warning: 'triangle-exclamation', info: 'circle-info' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<i class="fas fa-${icons[type] || icons.success}"></i><span>${esc(message)}</span>`;
  container.appendChild(el);
  requestAnimationFrame(() => {
    el.style.animation = 'slideInToast .4s cubic-bezier(.175,.885,.32,1.275) forwards';
  });
  const duration = type === 'error' ? 4200 : 3200;
  setTimeout(() => {
    el.style.animation = 'fadeOut .4s forwards';
    setTimeout(() => el.remove(), 400);
  }, duration);
}

function money(value) { return Number(value || 0).toLocaleString('fa-IR') + ' تومان'; }
function jdate(value) { return new Date(value).toLocaleDateString('fa-IR-u-ca-persian'); }
function esc(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}
function remaining(deadline) {
  const ms = new Date(deadline).getTime() - Date.now();
  if (ms <= 0) return '00:00';
  const m = Math.floor(ms / 60000), s = Math.floor((ms % 60000) / 1000);
  return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
}
function foodName(order) {
  return order.menuItemId?.foodId?.name || order.items?.map(i => i.foodId?.name).filter(Boolean).join('، ') || '-';
}
function dailyMenuIdOfOrder(order) {
  return String(order.menuItemId?.dailyMenuId?._id || order.menuItemId?.dailyMenuId || '');
}

async function loadMe() {
  const data = await api('/api/auth/me');
  if (data.success) {
    document.getElementById('userName').textContent = data.user.fullName || data.user.username;
    document.getElementById('userDept').textContent = data.user.department?.name || 'واحد عمومی';
  }
}

let announcementsCache = [];

function isDisplayableAnnouncement(item) {
  const title = String(item?.title || '').trim();
  const body = String(item?.body || '').trim();
  return Boolean(title && body);
}

function syncAnnouncementsUi(items, hasActive) {
  const root = document.getElementById('announcementsUi');
  const trigger = document.getElementById('announcementsTrigger');
  const countEl = document.getElementById('announcementsCount');
  const list = document.getElementById('announcementsList');
  const visibleItems = (items || []).filter(isDisplayableAnnouncement);
  const shouldShow = Boolean(hasActive) && visibleItems.length > 0;

  announcementsCache = shouldShow ? visibleItems : [];

  if (!root || !trigger || !list) return;

  if (!shouldShow) {
    root.hidden = true;
    trigger.hidden = true;
    list.innerHTML = '';
    if (countEl) countEl.textContent = '';
    closeAnnouncementsDrawer();
    return;
  }

  root.hidden = false;
  trigger.hidden = false;
  if (countEl) countEl.textContent = visibleItems.length.toLocaleString('fa-IR');
  list.innerHTML = renderAnnouncementCards(visibleItems);
}

function renderAnnouncementCards(items) {
  return items.map((item) => `
    <article class="announcement-card">
      <div class="announcement-card-title">${esc(item.title)}</div>
      <div class="announcement-card-body">${esc(item.body).replace(/\n/g, '<br>')}</div>
      ${item.expiresAt ? `<div class="announcement-card-meta"><i class="fas fa-clock"></i> تا ${jdate(item.expiresAt)}</div>` : ''}
    </article>
  `).join('');
}

function openAnnouncementsDrawer() {
  const drawer = document.getElementById('announcementsDrawer');
  const overlay = document.getElementById('announcementsOverlay');
  if (!drawer || !overlay || !announcementsCache.length) return;
  overlay.hidden = false;
  drawer.classList.add('is-open');
  drawer.setAttribute('aria-hidden', 'false');
  document.body.classList.add('ann-drawer-open');
}

function closeAnnouncementsDrawer() {
  const drawer = document.getElementById('announcementsDrawer');
  const overlay = document.getElementById('announcementsOverlay');
  if (!drawer || !overlay) return;
  drawer.classList.remove('is-open');
  drawer.setAttribute('aria-hidden', 'true');
  overlay.hidden = true;
  document.body.classList.remove('ann-drawer-open');
}

async function loadAnnouncements() {
  const root = document.getElementById('announcementsUi');
  if (!root) return;

  try {
    const data = await api('/api/announcements/active');
    if (!data.success) {
      syncAnnouncementsUi([], false);
      return;
    }
    syncAnnouncementsUi(data.data || [], data.hasActive ?? (data.data || []).length > 0);
  } catch {
    syncAnnouncementsUi([], false);
  }
}

document.getElementById('announcementsTrigger')?.addEventListener('click', openAnnouncementsDrawer);
document.getElementById('announcementsClose')?.addEventListener('click', closeAnnouncementsDrawer);
document.getElementById('announcementsOverlay')?.addEventListener('click', closeAnnouncementsDrawer);
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeAnnouncementsDrawer();
});

// Full list (no pagination) is needed by the menu to lock already-ordered days.
async function loadOrders() {
  const data = await api('/api/orders');
  ordersCache = data.success ? data.data : [];
}

let myOrdersPagination = { page: 1, limit: 10, total: 0, totalPages: 1 };

async function loadMyOrders(page = myOrdersPagination.page || 1) {
  if (page === 1 && ordersCache.length) {
    const limit = myOrdersPagination.limit || 10;
    myOrdersPagination = {
      page: 1,
      limit,
      total: ordersCache.length,
      totalPages: Math.max(1, Math.ceil(ordersCache.length / limit)),
    };
    renderOrders(ordersCache.slice(0, limit));
    return;
  }

  const params = new URLSearchParams({
    page: String(page),
    limit: String(myOrdersPagination.limit || 10),
  });
  const data = await api(`/api/orders?${params.toString()}`);
  const orders = data.success ? data.data : [];
  myOrdersPagination = data.pagination || { page, limit: myOrdersPagination.limit || 10, total: orders.length, totalPages: 1 };
  renderOrders(orders);
}

function goToMyOrdersPage(page) {
  const totalPages = Number(myOrdersPagination.totalPages || 1);
  loadMyOrders(Math.min(Math.max(Number(page) || 1, 1), totalPages));
}

function renderOrdersPagination() {
  const totalPages = Number(myOrdersPagination.totalPages || 1);
  if (totalPages <= 1) return '';
  const current = Number(myOrdersPagination.page || 1);
  const pages = [];
  const start = Math.max(1, current - 2);
  const end = Math.min(totalPages, current + 2);
  for (let page = start; page <= end; page += 1) pages.push(page);
  return `<div class="pagination-bar">
    <button class="page-btn" ${current <= 1 ? 'disabled' : ''} onclick="goToMyOrdersPage(${current - 1})">قبلی</button>
    ${pages.map(page => `<button class="page-btn ${page === current ? 'active' : ''}" onclick="goToMyOrdersPage(${page})">${page.toLocaleString('fa-IR')}</button>`).join('')}
    <button class="page-btn" ${current >= totalPages ? 'disabled' : ''} onclick="goToMyOrdersPage(${current + 1})">بعدی</button>
    <span class="page-summary">${Number(myOrdersPagination.total || 0).toLocaleString('fa-IR')} سفارش</span>
  </div>`;
}

function renderOrders(orders) {
  const wrap = document.getElementById('ordersWrap');
  if (!orders.length) {
    wrap.innerHTML = '<div class="orders-empty"><i class="fas fa-receipt"></i><p>هنوز سفارشی ثبت نکرده‌اید.</p></div>';
    return;
  }
  const statusLabel = { pending: 'در انتظار تایید', confirmed: 'تایید شده', ready: 'آماده', completed: 'تحویل شده', cancelled: 'لغو شده' };
  const statusClass = { pending: 'warning', confirmed: 'primary', ready: 'success', completed: 'success', cancelled: 'danger' };
  const priceHeader = showPricesToUsers ? '<th>مبلغ</th>' : '';

  wrap.innerHTML = `
    <table class="table">
      <thead><tr><th>کد سفارش</th><th>غذا</th>${priceHeader}<th>تاریخ ثبت</th><th>تاریخ تحویل</th><th>وضعیت</th></tr></thead>
      <tbody>${orders.map(order => `
        <tr>
          <td style="font-weight:900;direction:ltr">#${order.orderNumber || '-'}</td>
          <td style="font-weight:700">${esc(foodName(order))}</td>
          ${showPricesToUsers ? `<td>${money(order.totalPrice)}</td>` : ''}
          <td style="white-space:nowrap">${jdate(order.orderDate)}</td>
          <td style="white-space:nowrap">${order.deliveryDate ? jdate(order.deliveryDate) : '-'}</td>
          <td><span class="badge badge-${statusClass[order.status] || 'gray'}">${statusLabel[order.status] || order.status}</span></td>
        </tr>
      `).join('')}</tbody>
    </table>
    ${renderOrdersPagination()}`;
}

async function loadMenu() {
  await loadOrders();
  const data = await api('/api/menu/active');
  if (!data.success) {
    document.getElementById('noWeekOverlay').style.display = 'flex';
    document.getElementById('menuGrid').innerHTML = '<div class="empty-state"><i class="fas fa-calendar-xmark"></i><p>برنامه غذایی فعالی وجود ندارد.</p></div>';
    return;
  }
  menuCache = data.data;
  const pricesFlag = data.data.settings?.showPricesToUsers;
  showPricesToUsers = !(pricesFlag === false || pricesFlag === 'false' || pricesFlag === 0 || pricesFlag === '0');
  const statementFlag = data.data.settings?.showFinancialStatementToUsers;
  const statementFlagOn = !(statementFlag === false || statementFlag === 'false' || statementFlag === 0 || statementFlag === '0');
  applyCapabilities({
    showPrices: showPricesToUsers,
    showStatement: statementFlagOn,
  });
  defaultMenuItemCapacity = Number(data.data.settings?.defaultMenuItemCapacity ?? 20);
  syncStatementTabVisibility();
  document.getElementById('weekTitle').textContent = data.data.week.name || `${jdate(data.data.week.startDate)} تا ${jdate(data.data.week.endDate)}`;
  renderMenu();
}

function renderMenu() {
  const orderedDayIds = new Set(ordersCache.filter(o => o.status !== 'cancelled').map(dailyMenuIdOfOrder));
  const orderedItemIds = new Set(ordersCache.filter(o => o.status !== 'cancelled' && o.menuItemId).map(o => String(o.menuItemId._id || o.menuItemId)));

  const menuItemToOrder = {};
  ordersCache.filter(o => o.status !== 'cancelled' && o.menuItemId).forEach(o => {
    menuItemToOrder[String(o.menuItemId._id || o.menuItemId)] = o;
  });

  const html = menuCache.days.map(day => {
    const dayId = String(day._id);
    const dayLocked = orderedDayIds.has(dayId);
    return `
      <div class="day-card">
        <div class="day-card-header">
          <span class="day-name">${day.dayId?.name || ''}</span>
          <span class="day-date-badge">${jdate(day.date)}</span>
        </div>
        <div class="day-card-body">${day.items.length ? day.items.map(item => {
          const capacity = Number(item.effectiveCapacity) > 0
            ? Number(item.effectiveCapacity)
            : Number(defaultMenuItemCapacity) || 0;
          const full = capacity > 0 && item.reservedCount >= capacity;
          const selectedItem = orderedItemIds.has(String(item._id));
          const order = menuItemToOrder[String(item._id)];
          return `
            <div class="food-row">
              <div>
                <div class="food-name">${esc(item.foodId?.name || '-')}</div>
                ${showPricesToUsers ? `<div class="food-price">${money(item.price)}</div>` : ''}
                <div class="capacity-note">
                  <i class="fas fa-users" style="font-size:.7rem"></i>
                  رزرو: ${item.reservedCount || 0}${capacity ? ' از ' + capacity : ''}
                </div>
              </div>
              <div class="menu-actions">
                ${selectedItem
                  ? (order?.canCancel
                      ? `<button class="btn-cancel-order" onclick="cancelOrder('${order._id}')"><i class="fas fa-xmark"></i> لغو رزرو</button>`
                      : '<span class="status-confirmed"><i class="fas fa-check"></i> تایید شده</span>')
                  : dayLocked
                    ? '<button class="btn-reserve" disabled style="font-size:.75rem">سفارش دارید</button>'
                    : `<button class="btn-reserve" ${full ? 'disabled' : ''} onclick="placeOrder('${item._id}', this)">
                        ${full ? '<i class="fas fa-ban"></i> تکمیل' : '<i class="fas fa-plus"></i> رزرو'}
                       </button>`}
              </div>
            </div>`;
        }).join('') : '<div class="day-empty"><i class="fas fa-bowl-food"></i><p>غذایی برای این روز ثبت نشده</p></div>'}</div>
      </div>`;
  }).join('');

  const allEmpty = menuCache.days.every((day) => !day.items.length);
  document.getElementById('menuGrid').innerHTML = allEmpty
    ? `<div class="menu-notice"><i class="fas fa-info-circle"></i><span>منوی این هفته هنوز توسط مدیریت تکمیل نشده است. پس از ثبت غذاها می‌توانید رزرو کنید.</span></div>${html}`
    : html;
}

async function placeOrder(menuItemId, btn) {
  if (pendingMenuItems.has(menuItemId)) return;
  pendingMenuItems.add(menuItemId);
  const originalHtml = btn?.innerHTML;
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> در حال ثبت';
  }

  try {
    const data = await api('/api/orders', { method: 'POST', body: JSON.stringify({ menuItemId }) });
    if (!data.success) {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
      }
      return toast(data.message || 'ثبت سفارش ناموفق بود', 'error');
    }
    toast(data.message || 'رزرو شما با موفقیت ثبت شد', 'success');
    await loadMenu();
  } catch (e) {
    if (e?.message !== '401' && btn) {
      btn.disabled = false;
      btn.innerHTML = originalHtml;
      toast('خطا در اتصال — لطفاً دوباره تلاش کنید', 'error');
    }
  } finally {
    pendingMenuItems.delete(menuItemId);
  }
}

async function cancelOrder(orderId) {
  const data = await api(`/api/orders/${orderId}/cancel`, { method: 'POST' });
  if (!data.success) return toast(data.message || 'لغو سفارش ناموفق بود', 'error');
  toast('سفارش لغو شد');
  await loadMenu();
  loadMyOrders();
}

function syncStatementTabVisibility() {
  const btn = document.getElementById('statementTabBtn');
  if (btn) btn.hidden = !showFinancialStatementToUsers;
}

function renderStatementUnavailable() {
  const controls = document.querySelector('.statement-controls');
  const banner = document.getElementById('statementSplitBanner');
  const wrap = document.getElementById('statementTableWrap');
  if (controls) controls.style.display = 'none';
  if (banner) banner.style.display = 'none';
  if (wrap) {
    wrap.innerHTML = `<div class="orders-empty statement-unavailable">
      <i class="fas fa-lock"></i>
      <p style="font-weight:800;font-size:1.05rem">در حال حاضر در دسترس نیست</p>
      <p style="color:var(--text-muted);margin-top:8px">بخش صورتحساب مالی توسط مدیریت غیرفعال شده است.</p>
    </div>`;
  }
}

function renderStatementEnabledUi() {
  const controls = document.querySelector('.statement-controls');
  const banner = document.getElementById('statementSplitBanner');
  if (controls) controls.style.display = '';
  if (banner) banner.style.display = '';
}

function isStatementDisabledResponse(data) {
  return Boolean(data?.disabled)
    || data?.data?.showFinancialStatementToUsers === false
    || String(data?.message || '').includes('در دسترس نیست')
    || String(data?.message || '').includes('غیرفعال');
}

function isDbConnectionMessage(message) {
  const text = String(message || '');
  return text.includes('پایگاه داده') || text.includes('SERVICE_UNAVAILABLE');
}

async function refreshStatementConfig() {
  try {
    const data = await api('/api/user/statement/config');
    if (data.success && data.data) {
      applyCapabilities({
        showPrices: data.data.showPrices !== false && data.data.showPricesToUsers !== false,
        showStatement: data.data.showStatement !== false && data.data.showFinancialStatementToUsers !== false,
        organizationSharePercent: Number(data.data.organizationSharePercent || 0),
        personalSharePercent: Number(data.data.personalSharePercent || 0),
        statementDisabledMessage: data.data.statementDisabledMessage,
      });
    }
  } catch {
    // Keep server-rendered defaults when config API is temporarily unavailable.
  }
  syncStatementTabVisibility();
  return showFinancialStatementToUsers;
}

async function loadStatementConfig() {
  await refreshStatementConfig();
  if (showFinancialStatementToUsers) renderStatementSplitBanner();
}

function renderStatementSplitBanner() {
  const banner = document.getElementById('statementSplitBanner');
  if (!banner) return;
  banner.innerHTML = `
    <i class="fas fa-percent"></i>
    سهم سازمان: <strong>${statementSplitConfig.organizationSharePercent.toLocaleString('fa-IR')}٪</strong>
    — سهم شخص: <strong>${statementSplitConfig.personalSharePercent.toLocaleString('fa-IR')}٪</strong>
    <span class="statement-range">فقط سفارش‌های تاییدشده در صورتحساب لحاظ می‌شوند</span>`;
}

function switchStatementSubTab(tab) {
  statementSubTab = tab;
  document.querySelectorAll('[data-stmt-sub]').forEach((btn) => {
    btn.classList.toggle('active', btn.dataset.stmtSub === tab);
  });
  loadUserStatementList();
}

function renderStatementList(statements) {
  const wrap = document.getElementById('statementTableWrap');
  const periodLabel = statementSubTab === 'monthly' ? 'ماه' : 'هفته';
  if (!statements.length) {
    wrap.innerHTML = `<div class="orders-empty"><i class="fas fa-file-invoice"></i><p>صورتحساب ${periodLabel}ی ثبت‌شده‌ای وجود ندارد.</p></div>`;
    return;
  }

  wrap.innerHTML = `
    <table class="table statement-table">
      <thead>
        <tr>
          <th>شماره صورتحساب</th>
          <th>بازه</th>
          <th>تعداد وعده</th>
          <th>مبلغ کل</th>
          <th>سهم سازمان</th>
          <th>سهم شخص</th>
        </tr>
      </thead>
      <tbody>${statements.map((stmt) => {
        const summary = stmt.summary || {};
        const rangeText = stmt.title || `${stmt.range?.jalaliStart || ''} تا ${stmt.range?.jalaliEnd || ''}`;
        const activeBadge = stmt.isActive ? ' <span class="badge badge-primary" style="font-size:.7rem">فعال</span>' : '';
        return `
        <tr>
          <td class="statement-number-col">${esc(stmt.statementNumber || '—')}</td>
          <td style="font-weight:700;white-space:nowrap">${esc(rangeText)}${activeBadge}</td>
          <td>${Number(summary.mealCount || 0).toLocaleString('fa-IR')}</td>
          <td>${money(summary.grossTotal)}</td>
          <td class="statement-org-col">${money(summary.organizationAmount)}</td>
          <td class="statement-personal-col">${money(summary.personalAmount)}</td>
        </tr>`;
      }).join('')}</tbody>
    </table>`;
}

async function loadUserStatementList() {
  const enabled = await refreshStatementConfig();
  if (!enabled) {
    renderStatementUnavailable();
    return;
  }
  renderStatementEnabledUi();
  renderStatementSplitBanner();
  const wrap = document.getElementById('statementTableWrap');
  if (wrap) wrap.innerHTML = '<div style="padding:40px;text-align:center"><div class="spinner"></div></div>';

  const type = statementSubTab === 'monthly' ? 'month' : 'week';
  const data = await api(`/api/user/statement/list?type=${type}`);
  if (isStatementDisabledResponse(data)) {
    applyCapabilities({ showStatement: false });
    renderStatementUnavailable();
    return;
  }
  if (!data.success) {
    if (wrap) {
      const message = isDbConnectionMessage(data.message)
        ? 'در حال حاضر در دسترس نیست'
        : (data.message || 'خطا در دریافت صورتحساب');
      wrap.innerHTML = `<div class="orders-empty"><i class="fas fa-circle-exclamation"></i><p>${esc(message)}</p></div>`;
    }
    return;
  }
  renderStatementList(data.data || []);
}

async function initStatementTab() {
  await loadUserStatementList();
}

document.getElementById('stmtSubWeekly')?.addEventListener('click', () => switchStatementSubTab('weekly'));
document.getElementById('stmtSubMonthly')?.addEventListener('click', () => switchStatementSubTab('monthly'));

document.querySelectorAll('.tab-button').forEach(button => {
  button.addEventListener('click', () => {
    document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    button.classList.add('active');
    document.getElementById(`tab-${button.dataset.tab}`).classList.add('active');
    if (button.dataset.tab === 'orders') loadMyOrders();
    if (button.dataset.tab === 'statement') initStatementTab();
  });
});

loadMe();
applyCapabilities(caps);
loadStatementConfig();
loadAnnouncements();
loadMenu();
</script>

  <%- include('../partials/app-version') %>
</body>
</html>

