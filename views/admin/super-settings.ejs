<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/session-security') %>
  <title>تنظیمات سامانه — پنل سوپر ادمین</title>
  <%- include('../partials/head-assets', { includeSweetAlert: true }) %>
  <link rel="stylesheet" href="/css/enterprise-theme.css">
  <link rel="stylesheet" href="/css/theme-vars.css">
  <%- include('../partials/app-base-meta') %>
  <script src="<%= jsAsset('app-base') %>" defer></script>
  <script src="<%= jsAsset('security') %>" defer></script>
</head>
<body class="admin-body">

<%- include('partials/sidebar', { activePage: 'super-settings', isSuperadmin: true, sidebarMode: 'external' }) %>

<div class="main-content">
  <header class="top-header">
    <div class="date-chip"><i class="far fa-calendar-check"></i><span id="todayDate"></span></div>
    <div class="header-actions">
      <button type="button" id="priceToggleBtn" class="btn-header btn-site" onclick="toggleUserPrices()">
        <i class="fas fa-tags"></i> قیمت برای کاربران
      </button>
      <a href="/admin/dashboard" class="btn-header btn-site"><i class="fas fa-arrow-right"></i> بازگشت به داشبورد</a>
      <a href="/logout" class="btn-header btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
    </div>
  </header>

  <main class="content-wrapper">
    <div class="page-header">
      <div>
        <div class="ph-badge"><i class="fas fa-sliders"></i> سوپر ادمین</div>
        <div class="ph-title">تنظیمات سامانه</div>
        <div class="ph-sub">نام سازمان، ظاهر، LDAP و محدودیت‌های رزرو</div>
      </div>
      <i class="fas fa-sliders ph-icon"></i>
    </div>

    <%- include('partials/system-settings-tab', { standalone: true }) %>
  </main>
</div>

<script src="/vendor/sweetalert2/sweetalert2.min.js"></script>
<script src="<%= jsAsset('admin-core') %>"></script>
<script src="<%= jsAsset('admin-super-settings') %>" defer></script>
</body>
</html>
