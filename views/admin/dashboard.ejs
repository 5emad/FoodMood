if (currentUserRole === 'superadmin') loadSettings();
loadWeeks().then(() => loadWeeklyReport());
initBackupTab();
if (document.getElementById('securityNotifyBadge')) loadSecurityCenter();
showMonthlyReportPlaceholder();
buildMonthOptions();
</script>
