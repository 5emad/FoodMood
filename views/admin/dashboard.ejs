function api(url, options = {}) {
  const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
  return fetch(url, { ...options, credentials: 'same-origin', headers }).then(async r => {
    if (r.status === 401) { window.location.replace('/login?expired=1'); throw new Error('401'); }
    const text = await r.text();
    try { return JSON.parse(text); } catch { return { success: false, message: text || `HTTP ${r.status}` }; }
  });
}

function money(v) { return Number(v || 0).toLocaleString('fa-IR') + ' تومان'; }
function jdate(v) { return new Date(v).toLocaleDateString('fa-IR-u-ca-persian'); }
function badge(text, cls = 'gray') { return `<span class="badge badge-${cls}">${text}</span>`; }
function esc(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}
function renderEmptyState({ icon = 'fa-inbox', title, desc = '' }) {
  return `<div class="empty-state">
    <div class="empty-state-icon"><i class="fas ${esc(icon)}"></i></div>
    <div class="empty-state-title">${esc(title)}</div>
    ${desc ? `<div class="empty-state-desc">${esc(desc)}</div>` : ''}
  </div>`;
}
function renderPaginationBar(pagination, goFnName) {
  const totalPages = Number(pagination.totalPages || 1);
  const current = Number(pagination.page || 1);
  const total = Number(pagination.total || 0);
  if (totalPages <= 1) {
    return total ? `<div class="table-footer-meta"><span class="page-summary">${total.toLocaleString('fa-IR')} رکورد</span></div>` : '';
  }
  const pages = [];
  const start = Math.max(1, current - 2);
  const end = Math.min(totalPages, current + 2);
  for (let page = start; page <= end; page += 1) pages.push(page);
  return `<div class="pagination-bar">
    <button class="page-btn" ${current <= 1 ? 'disabled' : ''} onclick="${goFnName}(${current - 1})">قبلی</button>
    ${pages.map(page => `<button class="page-btn ${page === current ? 'active' : ''}" onclick="${goFnName}(${page})">${page.toLocaleString('fa-IR')}</button>`).join('')}
    <button class="page-btn" ${current >= totalPages ? 'disabled' : ''} onclick="${goFnName}(${current + 1})">بعدی</button>
    <span class="page-summary">${Number(pagination.total || 0).toLocaleString('fa-IR')} رکورد</span>
  </div>`;
}

const dialog = Swal.mixin({
  customClass: { popup: 'swal2-rtl' },
  confirmButtonText: 'باشه',
  cancelButtonText: 'انصراف',
  buttonsStyling: true,
  reverseButtons: true,
  heightAuto: false,
});

function notify(message, icon = 'success', title = '') {
  return dialog.fire({
    icon,
    title: title || (icon === 'success' ? 'انجام شد' : 'خطا'),
    text: message,
    timer: icon === 'success' ? 2200 : undefined,
    timerProgressBar: icon === 'success',
  });
}

function showSuperToken(token) {
  return dialog.fire({
    icon: 'warning',
    title: 'توکن سوپر ادمین ساخته شد',
    html: `<div style="text-align:right;line-height:1.9">این توکن فقط همین یک بار نمایش داده می‌شود و در دیتابیس قابل بازیابی نیست.</div><pre style="direction:ltr;text-align:left;background:#0f172a;color:#e2e8f0;padding:12px;border-radius:8px;white-space:pre-wrap;word-break:break-all">${token}</pre>`,
    confirmButtonText: 'متوجه شدم',
    timer: undefined,
    timerProgressBar: false,
  });
}

async function confirmAction({ title, text, confirmText = 'تایید', icon = 'question' }) {
  const result = await dialog.fire({
    icon,
    title,
    text,
    showCancelButton: true,
    confirmButtonText: confirmText,
    cancelButtonText: 'انصراف',
  });
  return result.isConfirmed;
}

/* ===== SETTINGS ===== */
async function loadSettings() {
  const data = await api('/api/admin/settings');
  if (data.success) {
    appSettings = data.data;
    fillSystemSettingsForm();
    const priceToggleBtn = document.getElementById('priceToggleBtn');
    if (priceToggleBtn) {
      priceToggleBtn.innerHTML = appSettings.showPricesToUsers
        ? '<i class="fas fa-tags"></i> قیمت: قابل نمایش'
        : '<i class="fas fa-eye-slash"></i> قیمت: مخفی';
    }
    const sidebarOrgEl = document.getElementById('sidebarOrgName');
    if (sidebarOrgEl) sidebarOrgEl.textContent = appSettings.organizationName || 'سامانه تغذیه';
    refreshThemeStylesheet();
  }
}

function refreshThemeStylesheet() {
  const link = document.querySelector('link[href^="/css/theme-vars.css"]');
  if (link) link.href = `/css/theme-vars.css?v=${Date.now()}`;
}

function currentThemePresetId() {
  const keys = ['themePrimary', 'themePrimaryLight', 'themePrimaryDark', 'themeGradientFrom', 'themeGradientTo'];
  const normalize = value => String(value || '').toLowerCase();
  const match = themePresets.find(preset => keys.every(key => normalize(appSettings[key]) === normalize(preset[key])));
  return match ? match.id : '';
}

function setThemeColorInputs(preset) {
  ['themePrimary', 'themePrimaryLight', 'themePrimaryDark', 'themeGradientFrom', 'themeGradientTo'].forEach((key) => {
    const input = document.getElementById(`set_${key}`);
    if (input) input.value = preset[key];
  });
}

function selectThemePreset(presetId) {
  const preset = themePresets.find(item => item.id === presetId);
  if (!preset) return;
  Object.assign(appSettings, {
    themePrimary: preset.themePrimary,
    themePrimaryLight: preset.themePrimaryLight,
    themePrimaryDark: preset.themePrimaryDark,
    themeGradientFrom: preset.themeGradientFrom,
    themeGradientTo: preset.themeGradientTo,
  });
  setThemeColorInputs(preset);
  renderThemeOptions(preset.id);
}

function renderThemeOptions(activeId = currentThemePresetId()) {
  const wrapper = document.getElementById('themeOptions');
  if (!wrapper) return;
  wrapper.innerHTML = themePresets.map(preset => `
    <button
      type="button"
      class="theme-option ${preset.id === activeId ? 'active' : ''}"
      role="radio"
      aria-checked="${preset.id === activeId ? 'true' : 'false'}"
      style="--theme-primary:${preset.themePrimary};--theme-light:${preset.themePrimaryLight};--theme-dark:${preset.themePrimaryDark};--theme-bg:color-mix(in srgb, ${preset.themePrimary} 10%, transparent)"
      onclick="selectThemePreset('${preset.id}')"
    >
      <span class="theme-swatch"></span>
      <span>${preset.label}</span>
    </button>
  `).join('');
}

function fillSystemSettingsForm() {
  const byId = id => document.getElementById(id);
  if (!byId('set_organizationName')) return;
  byId('set_organizationName').value = appSettings.organizationName || '';
  if (byId('set_publicUrl')) byId('set_publicUrl').value = appSettings.publicUrl || '';
  byId('set_maxActiveReservations').value = Number(appSettings.maxActiveReservations || 0);
  byId('set_defaultMenuItemCapacity').value = Number(appSettings.defaultMenuItemCapacity ?? 50);
  byId('set_themePrimary').value = appSettings.themePrimary || '#9B6DFF';
  byId('set_themePrimaryLight').value = appSettings.themePrimaryLight || '#C4A8FF';
  byId('set_themePrimaryDark').value = appSettings.themePrimaryDark || '#6C3FD4';
  byId('set_themeGradientFrom').value = appSettings.themeGradientFrom || '#3D0F18';
  byId('set_themeGradientTo').value = appSettings.themeGradientTo || '#5A1624';
  renderThemeOptions();
  byId('set_showPricesToUsers').value = String(Boolean(appSettings.showPricesToUsers));
  byId('set_ldapEnabled').value = String(Boolean(appSettings.ldapEnabled));
  byId('set_ldapUrl').value = appSettings.ldapUrl || '';
  byId('set_ldapSecurity').value = appSettings.ldapSecurity || 'ldaps';
  byId('set_ldapCaCertPath').value = appSettings.ldapCaCertPath || '';
  byId('set_ldapBaseDn').value = appSettings.ldapBaseDn || '';
  byId('set_ldapBindDn').value = appSettings.ldapBindDn || '';
  byId('set_ldapBindPassword').value = '';
  byId('set_ldapUserFilter').value = appSettings.ldapUserFilter || '(sAMAccountName={{username}})';
  const hint = document.getElementById('ldapPasswordHint');
  if (hint) {
    if (appSettings.ldapBindPasswordStored) {
      hint.textContent = 'رمز Bind با رمزنگاری چندلایه (scrypt + AES-256-GCM + HMAC) در دیتابیس ذخیره شده. برای تغییر، رمز جدید وارد و ذخیره کنید.';
    } else if (appSettings.ldapBindPasswordFromEnv) {
      hint.textContent = 'رمز Bind از LDAP_BIND_PASSWORD در .env خوانده می‌شود. برای ذخیره امن در DB، رمز را در فرم وارد و «ذخیره تنظیمات» بزنید.';
    } else {
      hint.textContent = 'رمز Bind با رمزنگاری چندلایه در DB ذخیره می‌شود. LDAP_ENCRYPTION_KEY روی سرور الزامی است.';
    }
  }
}

async function saveSystemSettings(event) {
  event.preventDefault();
  const body = {
    organizationName: document.getElementById('set_organizationName').value.trim(),
    publicUrl: document.getElementById('set_publicUrl')?.value.trim() || '',
    maxActiveReservations: Number(document.getElementById('set_maxActiveReservations').value || 0),
    defaultMenuItemCapacity: Number(document.getElementById('set_defaultMenuItemCapacity').value || 0),
    themePrimary: document.getElementById('set_themePrimary').value,
    themePrimaryLight: document.getElementById('set_themePrimaryLight').value,
    themePrimaryDark: document.getElementById('set_themePrimaryDark').value,
    themeGradientFrom: document.getElementById('set_themeGradientFrom').value,
    themeGradientTo: document.getElementById('set_themeGradientTo').value,
    showPricesToUsers: document.getElementById('set_showPricesToUsers').value === 'true',
    ldapEnabled: document.getElementById('set_ldapEnabled').value === 'true',
    ldapUrl: document.getElementById('set_ldapUrl').value.trim(),
    ldapSecurity: document.getElementById('set_ldapSecurity').value,
    ldapCaCertPath: document.getElementById('set_ldapCaCertPath').value.trim(),
    ldapBaseDn: document.getElementById('set_ldapBaseDn').value.trim(),
    ldapBindDn: document.getElementById('set_ldapBindDn').value.trim(),
    ldapUserFilter: document.getElementById('set_ldapUserFilter').value.trim(),
  };
  const ldapBindPassword = document.getElementById('set_ldapBindPassword').value;
  if (ldapBindPassword) body.ldapBindPassword = ldapBindPassword;
  const data = await api('/api/admin/settings', { method: 'POST', body: JSON.stringify(body) });
  if (data.success) {
    appSettings = data.data;
    fillSystemSettingsForm();
    loadSettings();
    notify(data.message || 'تنظیمات ذخیره شد.');
  } else {
    notify(data.message || 'خطا در ذخیره تنظیمات', 'error');
  }
}

async function toggleUserPrices() {
  const data = await api('/api/admin/settings', { method: 'POST', body: JSON.stringify({ showPricesToUsers: !appSettings.showPricesToUsers }) });
  if (data.success) { appSettings = data.data; loadSettings(); }
  else notify(data.message || 'خطا', 'error');
}

