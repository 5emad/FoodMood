<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/session-security') %>
  <title>پنل مدیریت تغذیه</title>
  <%- include('../partials/head-assets', { includeSweetAlert: true }) %>
  <link rel="stylesheet" href="/css/enterprise-theme.css">
  <link rel="stylesheet" href="/css/theme-vars.css">
  <link rel="stylesheet" href="/vendor/jalalidatepicker/jalalidatepicker.min.css">
  <script src="/js/security.js?v=5" defer></script>
</head>
<body class="admin-body">

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="sidebar-brand-icon"><i class="fas fa-chart-pie"></i></div>
    <div>
      <span class="sidebar-brand-text" id="sidebarOrgName">سامانه تغذیه</span>
      <span class="sidebar-brand-sub">پنل مدیریت</span>
    </div>
  </div>
  <ul class="sidebar-nav">
    <li><div class="sidebar-section-title">مدیریت</div></li>
    <li><a class="sidebar-link active" data-tab="reports"><i class="fas fa-chart-line"></i><span>گزارش‌ها</span></a></li>
    <li><a class="sidebar-link" data-tab="weeks"><i class="fas fa-calendar-week"></i><span>هفته‌ها</span></a></li>
    <li><a class="sidebar-link" data-tab="orders"><i class="fas fa-clipboard-list"></i><span>سفارش‌ها</span></a></li>
    <li><a class="sidebar-link" data-tab="foods"><i class="fas fa-utensils"></i><span>غذاها</span></a></li>
    <li><div class="sidebar-section-title">تنظیمات</div></li>
    <li><a class="sidebar-link" data-tab="users"><i class="fas fa-users"></i><span>کاربران</span></a></li>
    <li><a class="sidebar-link" data-tab="departments"><i class="fas fa-building"></i><span>واحدها</span></a></li>
    <li><a class="sidebar-link" data-tab="announcements"><i class="fas fa-bullhorn"></i><span>اطلاعیه</span></a></li>
    <li><a class="sidebar-link" data-tab="backup"><i class="fas fa-database"></i><span>پشتیبان‌گیری</span></a></li>
    <% if (user && user.role === 'superadmin') { %>
      <li><a class="sidebar-link" data-tab="system-settings"><i class="fas fa-sliders"></i><span>تنظیمات سامانه</span></a></li>
    <% } %>
    <% if (user && user.role === 'superadmin') { %>
      <li><a class="sidebar-link" data-tab="security"><i class="fas fa-shield-halved"></i><span>امنیت</span> <span id="securityNotifyBadge" class="badge badge-danger" style="display:none;margin-right:auto">0</span></a></li>
    <% } %>
  </ul>
  <div class="sidebar-footer">
    <div class="user-avatar">م</div>
    <div class="sidebar-footer-info">
      <span class="sidebar-user-name">مدیر سیستم</span>
      <span class="sidebar-user-role">دسترسی ارشد</span>
      <span class="sidebar-app-version">نسخه <%= appVersionMajorFa %><% if (appVersion && String(appVersion) !== String(appVersionMajor)) { %> (<%= appVersionFa %>)<% } %></span>
    </div>
  </div>
</aside>

<!-- Main Content -->
<div class="main-content">
  <header class="top-header">
    <div class="date-chip"><i class="far fa-calendar-check"></i><span id="todayDate"></span></div>
    <div class="header-actions">
      <% if (user && user.role === 'superadmin') { %>
      <button type="button" id="priceToggleBtn" class="btn-header btn-site" onclick="toggleUserPrices()">
        <i class="fas fa-tags"></i> قیمت برای کاربران
      </button>
      <% } %>
      <a href="/user/dashboard" class="btn-header btn-site"><i class="fas fa-eye"></i> مشاهده پرتال</a>
      <a href="/logout" class="btn-header btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
    </div>
  </header>

  <main class="content-wrapper">
    <div class="page-header">
      <div>
        <div class="ph-badge"><i class="fas fa-cogs"></i> مدیریت سیستم</div>
        <div class="ph-title">مدیریت هوشمند تغذیه</div>
        <div class="ph-sub"></div>
      </div>
      <i class="fas fa-cogs ph-icon"></i>
    </div>

    <!-- ===== REPORTS ===== -->
    <section id="tab-reports" class="tab-pane active">
      <div class="section-header no-print">
        <div>
          <div class="section-title">گزارش‌ها</div>
          <div class="section-sub">گزارش هفتگی و ماهیانه سفارشات</div>
        </div>
        <div class="report-controls" id="reportActions">
          <div class="sub-tabs">
            <button class="sub-tab-btn active" data-sub="weekly" onclick="switchSubTab('weekly')"><i class="fas fa-calendar-week"></i> هفتگی</button>
            <button class="sub-tab-btn" data-sub="monthly" onclick="switchSubTab('monthly')"><i class="fas fa-calendar"></i> ماهیانه</button>
          </div>
          <select class="form-control" id="reportWeekSelect" style="width:240px" onchange="onReportWeekChange()"></select>
          <button class="btn btn-primary btn-sm" onclick="downloadPdf()" id="pdfBtn">
            <i class="fas fa-file-pdf"></i> دانلود PDF
          </button>
        </div>
      </div>

      <div id="sub-weekly" class="sub-pane active">
        <div class="print-title" id="printTitleWeekly"></div>
        <div id="weeklyReportWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
        <div class="daily-stats-grid" id="dailyStatsGrid"></div>
      </div>

      <div id="sub-monthly" class="sub-pane">
        <div class="print-title" id="printTitleMonthly"></div>
        <div class="section-header no-print" style="margin-top:0;padding-top:0">
          <div><div class="section-title">گزارش ماهیانه</div><div class="section-sub">انتخاب ماه شمسی</div></div>
          <div class="d-flex gap-2" style="flex-wrap:wrap;align-items:center">
            <select class="form-control" id="monthSelect" style="width:200px" onchange="loadMonthlyBySelect()">
              <option value="">— ماه را انتخاب کنید —</option>
            </select>
          </div>
        </div>
        <div id="monthlyReportWrap"></div>
      </div>
    </section>

    <!-- ===== WEEKS MANAGEMENT ===== -->
    <section id="tab-weeks" class="tab-pane">
      <div class="section-header">
        <div>
          <div class="section-title">مدیریت هفته‌ها</div>
          <div class="section-sub">برای هر هفته منو تعریف کنید، هفته را فعال یا غیرفعال کنید.</div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="createCurrentWeek()">
          <i class="fas fa-sync-alt"></i> ساخت هفته جاری
        </button>
      </div>
      <div id="weeksListWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
    </section>

    <!-- ===== ORDERS ===== -->
    <section id="tab-orders" class="tab-pane">
      <div class="section-header">
        <div><div class="section-title">سفارش‌ها</div><div class="section-sub">پس از بررسی، سفارش‌های هفته جاری را یکجا تایید کنید.</div></div>
        <div class="order-toolbar">
          <div class="search-group">
            <i class="fas fa-search search-group-icon"></i>
            <input id="orderSearchInput" type="number" min="100" placeholder="کد سفارش" onkeydown="if(event.key==='Enter') searchOrders()">
            <button type="button" class="search-clear" onclick="clearOrderSearch()" title="پاک کردن جستجو"><i class="fas fa-times"></i></button>
            <button type="button" class="search-go" onclick="searchOrders()">جستجو</button>
          </div>
          <button class="btn btn-success btn-confirm-week" onclick="confirmAllOrders(this)">
            <i class="fas fa-check-double"></i> تایید سفارش‌های کل هفته
          </button>
        </div>
      </div>
      <div class="table-wrap" id="ordersWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
    </section>

    <% if (user && user.role === 'superadmin') { %>
    <section id="tab-security" class="tab-pane">
      <div class="section-header">
        <div>
          <div class="section-title">مرکز امنیت سوپر ادمین</div>
          <div class="section-sub">لاگ ورود، تلاش‌های ناموفق، حساب‌های قفل‌شده و عملیات آنلاک</div>
        </div>
        <div class="d-flex gap-2" style="flex-wrap:wrap">
          <button class="btn btn-warning btn-sm" onclick="resetOwnSuperToken()"><i class="fas fa-key"></i> تغییر توکن من</button>
          <button class="btn btn-outline btn-sm" onclick="loadSecurityCenter()"><i class="fas fa-rotate"></i> بروزرسانی</button>
        </div>
      </div>

      <div class="stat-grid" id="securityStats">
        <div class="stat-card"><div class="stat-icon red"><i class="fas fa-lock"></i></div><div><div class="stat-value" id="lockedCount">0</div><div class="stat-label">حساب قفل‌شده</div></div></div>
        <div class="stat-card"><div class="stat-icon yellow"><i class="fas fa-triangle-exclamation"></i></div><div><div class="stat-value" id="failedCount">0</div><div class="stat-label">تلاش ناموفق ۲۴ ساعت</div></div></div>
        <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-bell"></i></div><div><div class="stat-value" id="securityUnreadCount">0</div><div class="stat-label">رخداد مهم اخیر</div></div></div>
      </div>

      <div class="card">
        <div class="card-header"><div class="card-title">کاربران قفل‌شده</div></div>
        <div class="card-body"><div class="table-wrap" id="lockedUsersWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div></div>
      </div>

      <div class="card">
        <div class="card-header"><div class="card-title">تلاش‌های ناموفق پرتکرار</div></div>
        <div class="card-body"><div class="table-wrap" id="failedSummaryWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div></div>
      </div>

      <div class="card">
        <div class="card-header"><div class="card-title">آخرین لاگ‌های امنیتی</div></div>
        <div class="card-body"><div class="table-wrap" id="securityLogsWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div></div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="fas fa-server" style="margin-left:8px;color:var(--primary)"></i> لاگ‌های سیستمی</div>
          <span id="systemHealthBadge" class="badge badge-success">سالم</span>
        </div>
        <div class="card-body">
          <p class="section-sub" style="margin-bottom:12px">استارت/استاپ سرور، قطع و وصل دیتابیس — فقط برای سوپر ادمین. کاربران صفحه آرامش‌بخش «در دسترس نیست» می‌بینند.</p>
          <div class="stat-grid" id="lifecycleStats" style="margin-bottom:16px">
            <div class="stat-card"><div class="stat-icon green"><i class="fas fa-play"></i></div><div><div class="stat-value" id="lcServerStarts">0</div><div class="stat-label">استارت سرور</div></div></div>
            <div class="stat-card"><div class="stat-icon yellow"><i class="fas fa-stop"></i></div><div><div class="stat-value" id="lcServerStops">0</div><div class="stat-label">استاپ سرور</div></div></div>
            <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-database"></i></div><div><div class="stat-value" id="lcDbConnects">0</div><div class="stat-label">اتصال دیتابیس</div></div></div>
            <div class="stat-card"><div class="stat-icon red"><i class="fas fa-plug-circle-xmark"></i></div><div><div class="stat-value" id="lcDbDisconnects">0</div><div class="stat-label">قطع دیتابیس</div></div></div>
          </div>
          <div id="systemTestWrap" style="display:none;margin-bottom:14px">
            <button class="btn btn-warning btn-sm" onclick="runDbOutageTest(this)"><i class="fas fa-vial"></i> تست قطعی دیتابیس (۳۰ ثانیه)</button>
            <span class="text-muted" style="font-size:.8rem;margin-right:10px">فقط حالت تست — صفحه «در دسترس نیست» را در تب ناشناس بررسی کنید</span>
          </div>
          <div class="d-flex gap-2" style="flex-wrap:wrap;margin-bottom:12px;align-items:center">
            <select class="form-control" id="systemLogLevelFilter" style="width:160px" onchange="systemLogLevelFilterChanged()">
              <option value="">همه سطوح</option>
              <option value="error">فقط خطا</option>
              <option value="warn">فقط هشدار</option>
              <option value="info">فقط اطلاع</option>
            </select>
            <button class="btn btn-outline btn-sm" onclick="loadSystemLogs()"><i class="fas fa-rotate"></i> بروزرسانی</button>
          </div>
          <div class="table-wrap" id="systemLogsWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
          <div id="systemLogsPagination" class="d-flex gap-2" style="flex-wrap:wrap;justify-content:center;margin-top:14px"></div>
        </div>
      </div>
    </section>
    <% } %>

    <!-- ===== USERS MANAGEMENT ===== -->
    <section id="tab-users" class="tab-pane">
      <div class="section-header">
        <div><div class="section-title">مدیریت کاربران</div><div class="section-sub">افزودن، ویرایش و غیرفعال‌سازی کاربران سامانه</div></div>
        <button class="btn btn-primary btn-sm" onclick="openAddUser()"><i class="fas fa-user-plus"></i> کاربر جدید</button>
      </div>
      <div id="userFormWrap" class="card" style="display:none;margin-bottom:18px">
        <div class="card-header">
          <div class="card-title" id="userFormTitle">افزودن کاربر</div>
          <button class="btn-icon" onclick="closeUserForm()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-body">
          <form id="userForm" onsubmit="saveUser(event)" autocomplete="off">
            <input type="hidden" id="editUserId" value="">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px">
              <div class="form-group">
                <label class="form-label">نام کاربری *</label>
                <input class="form-control" name="username" id="uf_username" required placeholder="مثال: 09121234567">
              </div>
              <div class="form-group">
                <label class="form-label">نام کامل (فارسی) *</label>
                <input class="form-control" name="fullName" id="uf_fullName" required placeholder="علی احمدی">
              </div>
              <div class="form-group">
                <label class="form-label">رمز عبور</label>
                <input class="form-control" name="password" id="uf_password" type="password" placeholder="در ویرایش خالی = بدون تغییر" autocomplete="new-password">
              </div>
              <div class="form-group">
                <label class="form-label">ایمیل</label>
                <input class="form-control" name="email" id="uf_email" type="email" dir="ltr">
              </div>
              <div class="form-group">
                <label class="form-label">موبایل</label>
                <input class="form-control" name="phone" id="uf_phone" dir="ltr" placeholder="09121234567">
              </div>
              <div class="form-group">
                <label class="form-label">واحد</label>
                <select class="form-control" name="departmentId" id="uf_dept"><option value="">بدون واحد</option></select>
              </div>
              <div class="form-group">
                <label class="form-label">نقش</label>
                <select class="form-control" name="role" id="uf_role">
                  <option value="user">کاربر عادی</option>
                  <option value="admin">مدیر</option>
                  <% if (user && user.role === 'superadmin') { %><option value="superadmin">سوپر ادمین</option><% } %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">وضعیت</label>
                <select class="form-control" name="status" id="uf_status">
                  <option value="active">فعال</option>
                  <option value="inactive">غیرفعال</option>
                </select>
              </div>
            </div>
            <div style="margin-top:14px;display:flex;gap:10px">
              <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> ذخیره</button>
              <button class="btn btn-outline" type="button" onclick="closeUserForm()">انصراف</button>
            </div>
          </form>
        </div>
      </div>
      <div class="table-wrap" id="usersTableWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
    </section>

    <!-- ===== DEPARTMENTS ===== -->
    <section id="tab-departments" class="tab-pane">
      <div class="section-header">
        <div><div class="section-title">مدیریت واحدهای سازمانی</div><div class="section-sub">افزودن، ویرایش و حذف واحدهای سازمان</div></div>
        <button class="btn btn-primary btn-sm" onclick="openAddDept()"><i class="fas fa-plus"></i> واحد جدید</button>
      </div>
      <div id="deptFormWrap" class="card" style="display:none;margin-bottom:18px">
        <div class="card-header">
          <div class="card-title" id="deptFormTitle">افزودن واحد</div>
          <button class="btn-icon" onclick="closeDeptForm()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-body">
          <form id="deptForm" onsubmit="saveDept(event)">
            <input type="hidden" id="editDeptId" value="">
            <div style="display:flex;gap:12px;align-items:flex-end">
              <div class="form-group" style="flex:1;margin:0">
                <label class="form-label">نام واحد *</label>
                <input class="form-control" id="df_name" required placeholder="مثال: واحد مالی">
              </div>
              <div style="display:flex;gap:8px">
                <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> ذخیره</button>
                <button class="btn btn-outline" type="button" onclick="closeDeptForm()">انصراف</button>
              </div>
            </div>
          </form>
        </div>
      </div>
      <div class="table-wrap" id="deptsTableWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
    </section>

    <!-- ===== ANNOUNCEMENTS ===== -->
    <section id="tab-announcements" class="tab-pane">
      <div class="section-header">
        <div>
          <div class="section-title">مدیریت اطلاعیه‌ها</div>
          <div class="section-sub">ارسال پیام به همه کاربران یا واحدهای مشخص — متن در دیتابیس رمزنگاری می‌شود</div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openAddAnnouncement()"><i class="fas fa-plus"></i> اطلاعیه جدید</button>
      </div>
      <div id="announcementFormWrap" class="card" style="display:none;margin-bottom:18px">
        <div class="card-header">
          <div class="card-title" id="announcementFormTitle">ثبت اطلاعیه</div>
          <button class="btn-icon" onclick="closeAnnouncementForm()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-body">
          <form id="announcementForm" onsubmit="saveAnnouncement(event)">
            <input type="hidden" id="editAnnouncementId" value="">
            <div class="form-group">
              <label class="form-label">عنوان *</label>
              <input class="form-control" id="ann_title" required maxlength="120" placeholder="مثال: تعطیلی سلف سرویس">
            </div>
            <div class="form-group">
              <label class="form-label">متن اطلاعیه *</label>
              <textarea class="form-control" id="ann_body" required rows="4" maxlength="2000" placeholder="متن پیام برای کاربران"></textarea>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
              <div class="form-group">
                <label class="form-label">مخاطب</label>
                <select class="form-control" id="ann_audience" onchange="toggleAnnouncementDepts()">
                  <option value="all">همه کاربران سامانه</option>
                  <option value="department">واحد مشخص</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">وضعیت</label>
                <select class="form-control" id="ann_active">
                  <option value="1">فعال (نمایش به کاربران)</option>
                  <option value="0">غیرفعال</option>
                </select>
              </div>
            </div>
            <div class="form-group" id="ann_depts_wrap" style="display:none">
              <label class="form-label">واحدهای هدف *</label>
              <select class="form-control" id="ann_departments" multiple size="5"></select>
              <div class="text-muted" style="font-size:.75rem;margin-top:6px">برای انتخاب چند واحد، Ctrl را نگه دارید</div>
            </div>
            <div class="form-group">
              <label class="form-label">تاریخ انقضا (شمسی — اختیاری)</label>
              <input class="form-control" id="ann_expires" data-jdp data-jdp-only-date placeholder="مثال: ۱۴۰۴/۰۴/۲۰">
            </div>
            <div style="display:flex;gap:10px;margin-top:8px">
              <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> ذخیره</button>
              <button class="btn btn-outline" type="button" onclick="closeAnnouncementForm()">انصراف</button>
            </div>
          </form>
        </div>
      </div>
      <div class="table-wrap" id="announcementsTableWrap"><div style="padding:32px;text-align:center"><div class="spinner"></div></div></div>
    </section>

    <!-- ===== BACKUP / RESTORE ===== -->
    <section id="tab-backup" class="tab-pane">
      <div class="section-header">
        <div>
          <div class="section-title">پشتیبان‌گیری و بازیابی</div>
          <div class="section-sub">خروجی امن از داده‌های سامانه و بازگردانی در صورت از دست رفتن اطلاعات</div>
        </div>
      </div>

      <div class="backup-grid">
        <div class="card backup-card">
          <div class="card-header">
            <div class="card-title"><i class="fas fa-download" style="margin-left:8px;color:var(--primary)"></i> دریافت پشتیبان</div>
          </div>
          <div class="card-body">
            <p class="backup-desc">یک فایل اختصاصی <code>.fzbackup</code> از تمام داده‌های سامانه (کاربران، غذاها، هفته‌ها، منوها، سفارش‌ها و تنظیمات) دریافت کنید.</p>
            <ul class="backup-features">
