          <td style="font-weight:900;direction:ltr">#${o.orderNumber || '-'}</td>
          <td style="font-weight:700">${esc(o.userId?.fullName || o.userId?.username || o.orderUserName || o.ldapUsername || '-')}</td>
          <td>${esc(o.menuItemId?.foodId?.name || o.items?.[0]?.foodId?.name || '-')}</td>
          <td>${money(o.totalPrice)}</td>
          <td><span class="badge badge-${clsMap[o.status] || 'gray'}">${labels[o.status] || o.status}</span></td>
          <td>${jdate(o.orderDate)}</td>
          <td>
            ${o.status !== 'cancelled'
              ? `<button class="btn btn-danger btn-sm" onclick="cancelAdminOrder('${o.orderNumber || o._id}')"><i class="fas fa-ban"></i> لغو</button>`
              : '<span class="badge badge-gray">لغو شده</span>'}
          </td>
        </tr>`).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--text-muted)">سفارشی ثبت نشده</td></tr>'}
      </tbody>
    </table>
    ${renderOrderPagination()}`;
}

function renderOrderPagination() {
  return renderPaginationBar(orderPagination, 'goToOrdersPage');
}

function goToOrdersPage(page) {
  const totalPages = Number(orderPagination.totalPages || 1);
  const nextPage = Math.min(Math.max(Number(page) || 1, 1), totalPages);
  loadOrders(nextPage);
}

function searchOrders() {
  orderPagination.page = 1;
  loadOrders(1);
}

function clearOrderSearch() {
  const input = document.getElementById('orderSearchInput');
  if (input) input.value = '';
  orderPagination.page = 1;
  loadOrders(1);
}

async function cancelAdminOrder(orderNumber) {
  if (!(await confirmAction({
    title: `لغو سفارش #${orderNumber}؟`,
    text: 'این سفارش برای کاربر لغو می‌شود و ظرفیت رزرو آزاد می‌شود.',
    confirmText: 'لغو سفارش',
    icon: 'warning',
  }))) return;

  const data = await api(`/api/orders/admin/${encodeURIComponent(orderNumber)}/cancel`, { method: 'POST' });
  if (data.success) {
    notify(data.message || 'سفارش لغو شد.');
    loadOrders();
  } else {
    notify(data.message || 'خطا در لغو سفارش', 'error');
  }
}

/* ===== FOODS ===== */
const foodsMap = new Map();
let foodPagination = { page: 1, limit: 20, total: 0, totalPages: 1 };

// Full list for the week menu editor (no pagination).
async function loadAllFoods() {
  const data = await api('/api/foods?includeInactive=true');
  foods = data.success ? data.data : [];
}

async function loadFoods(page = foodPagination.page || 1) {
  const params = new URLSearchParams({
    includeInactive: 'true',
    page: String(page),
    limit: String(foodPagination.limit || 20),
  });
  const data = await api(`/api/foods?${params.toString()}`);
  const pageFoods = data.success ? data.data : [];
  foodPagination = data.pagination || { page, limit: foodPagination.limit || 20, total: pageFoods.length, totalPages: 1 };
  foodsMap.clear();
  pageFoods.forEach(f => foodsMap.set(String(f._id), f));
  const tbody = document.querySelector('#foodsTable tbody');
  const catLabel = { lunch: 'ناهار', breakfast: 'صبحانه', dinner: 'شام', snack: 'میان وعده' };
  if (tbody) tbody.innerHTML = pageFoods.map(f => `
    <tr>
      <td style="font-weight:700">${esc(f.name)}</td>
      <td><span class="badge badge-primary">${esc(catLabel[f.category] || f.category)}</span></td>
      <td>${money(f.price)}</td>
      <td style="white-space:nowrap">
        <button class="btn btn-outline btn-sm" onclick="editFood('${f._id}')"><i class="fas fa-edit"></i></button>
        <button class="btn btn-danger btn-sm" onclick="deleteFood('${f._id}')"><i class="fas fa-trash"></i></button>
      </td>
    </tr>`).join('') || '<tr><td colspan="4" style="text-align:center;color:var(--text-muted)">غذایی ثبت نشده</td></tr>';
  const pagerWrap = document.getElementById('foodsPagination');
  if (pagerWrap) pagerWrap.innerHTML = renderPaginationBar(foodPagination, 'goToFoodsPage');
}

function goToFoodsPage(page) {
  const totalPages = Number(foodPagination.totalPages || 1);
  loadFoods(Math.min(Math.max(Number(page) || 1, 1), totalPages));
}

function editFood(id) {
  const f = foodsMap.get(String(id));
  if (!f) return;
  document.getElementById('editFoodId').value = id;
  document.getElementById('ef_name').value = f.name;
  document.getElementById('ef_price').value = f.price;
  document.getElementById('ef_category').value = f.category;
  document.getElementById('foodEditWrap').style.display = 'block';
  document.getElementById('foodEditWrap').scrollIntoView({ behavior: 'smooth' });
}

async function saveFoodEdit(event) {
  event.preventDefault();
  const id = document.getElementById('editFoodId').value;
  const body = {
    name: document.getElementById('ef_name').value,
    price: Number(document.getElementById('ef_price').value),
    category: document.getElementById('ef_category').value,
  };
  const data = await api(`/api/foods/${id}`, { method: 'PUT', body: JSON.stringify(body) });
  if (data.success) { document.getElementById('foodEditWrap').style.display = 'none'; loadFoods(); }
  else notify(data.message || 'خطا در ویرایش', 'error');
}

async function deleteFood(id) {
  if (!(await confirmAction({
    title: 'حذف غذا؟',
    text: 'این غذا از فهرست غذاها حذف می‌شود.',
    confirmText: 'حذف غذا',
    icon: 'warning',
  }))) return;
  const data = await api(`/api/foods/${id}`, { method: 'DELETE' });
  if (data.success) { loadFoods(); notify(data.message || 'غذا حذف شد.'); } else notify(data.message || 'خطا در حذف', 'error');
}

document.getElementById('foodForm').addEventListener('submit', async e => {
  e.preventDefault();
  const body = Object.fromEntries(new FormData(e.target).entries());
  body.price = Number(body.price);
  const data = await api('/api/foods', { method: 'POST', body: JSON.stringify(body) });
  if (data.success) { e.target.reset(); loadFoods(); notify(data.message || 'غذا اضافه شد.'); } else notify(data.message || 'خطا در ذخیره', 'error');
});

/* ===== USERS MANAGEMENT ===== */
let departments = [];
let editingUserId = null;
const usersMap = new Map();
let userPagination = { page: 1, limit: 20, total: 0, totalPages: 1 };

async function loadUsers(page = userPagination.page || 1) {
  const params = new URLSearchParams({
    page: String(page),
    limit: String(userPagination.limit || 20),
  });
  const [usersData, deptData] = await Promise.all([
    api(`/api/admin/users?${params.toString()}`),
    api('/api/admin/departments'),
  ]);
  departments = deptData.success ? deptData.data : [];
  const users = usersData.success ? usersData.data : [];
  userPagination = usersData.pagination || { page, limit: userPagination.limit || 20, total: users.length, totalPages: 1 };
  usersMap.clear();
  users.forEach(u => usersMap.set(String(u._id), u));
  const roleLabel = { admin: 'مدیر', superadmin: 'سوپر ادمین', user: 'کاربر' };
  const statusBadge = { active: 'badge-success', inactive: 'badge-danger' };
  document.getElementById('usersTableWrap').innerHTML = `
    <table class="table">
      <thead><tr><th>نام کامل</th><th>نام کاربری</th><th>واحد</th><th>نقش</th><th>وضعیت</th><th>عملیات</th></tr></thead>
      <tbody>${users.map(u => `
        <tr>
          <td style="font-weight:700">${esc(u.fullName || '-')}</td>
          <td style="direction:ltr;text-align:center">${esc(u.username)}</td>
          <td>${esc(u.departmentId?.name || '-')}</td>
          <td>${esc(roleLabel[u.role] || u.role)}</td>
          <td><span class="badge ${statusBadge[u.status] || 'badge-gray'}">${u.status === 'active' ? 'فعال' : 'غیرفعال'}</span></td>
          <td style="white-space:nowrap">
            <button class="btn btn-outline btn-sm" onclick="openEditUser('${u._id}')"><i class="fas fa-edit"></i></button>
            ${String(u._id) === String(currentUserId)
              ? '<span class="badge badge-gray" title="حساب خودتان قابل حذف نیست">شما</span>'
              : `<button class="btn btn-danger btn-sm" onclick="deleteUser('${u._id}')"><i class="fas fa-trash"></i></button>`}
          </td>
        </tr>`).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text-muted)">کاربری ثبت نشده</td></tr>'}
      </tbody>
    </table>
    ${renderPaginationBar(userPagination, 'goToUsersPage')}`;
}

function goToUsersPage(page) {
  const totalPages = Number(userPagination.totalPages || 1);
  loadUsers(Math.min(Math.max(Number(page) || 1, 1), totalPages));
}

function populateDeptSelect(selectedId) {
  const sel = document.getElementById('uf_dept');
  sel.innerHTML = '<option value="">بدون واحد</option>' +
    departments.map(d => `<option value="${d._id}" ${String(d._id) === String(selectedId) ? 'selected' : ''}>${esc(d.name)}</option>`).join('');
}

function resetUserFormGuards() {
  const statusEl = document.getElementById('uf_status');
  const roleEl = document.getElementById('uf_role');
  if (statusEl) {
    statusEl.disabled = false;
    statusEl.title = '';
  }
  if (roleEl) {
    Array.from(roleEl.options).forEach((opt) => { opt.disabled = false; });
    roleEl.title = '';
  }
}

function applySelfUserFormGuards(userId, userRole) {
  resetUserFormGuards();
  if (String(userId) !== String(currentUserId)) return;

  const statusEl = document.getElementById('uf_status');
  const roleEl = document.getElementById('uf_role');
  if (statusEl) {
    statusEl.value = 'active';
    statusEl.disabled = true;
    statusEl.title = 'امکان غیرفعال‌سازی حساب خودتان وجود ندارد';
  }
  if (roleEl) {
    const ranks = { user: 0, admin: 1, superadmin: 2 };
    const currentRank = ranks[userRole] ?? 0;
    Array.from(roleEl.options).forEach((opt) => {
      opt.disabled = (ranks[opt.value] ?? 0) < currentRank;
    });
    roleEl.title = 'امکان تنزل نقش حساب خودتان وجود ندارد';
  }
}

function openAddUser() {
  editingUserId = null;
  document.getElementById('userFormTitle').textContent = 'افزودن کاربر';
  document.getElementById('editUserId').value = '';
  document.getElementById('userForm').reset();
  document.getElementById('uf_role').value = 'admin';
  resetUserFormGuards();
  populateDeptSelect('');
  document.getElementById('userFormWrap').style.display = 'block';
  document.getElementById('userFormWrap').scrollIntoView({ behavior: 'smooth' });
}

function openEditUser(id) {
  const u = usersMap.get(String(id));
  if (!u) return;
  editingUserId = id;
  document.getElementById('userFormTitle').textContent = 'ویرایش کاربر';
  document.getElementById('editUserId').value = id;
  document.getElementById('uf_username').value = u.username || '';
  document.getElementById('uf_fullName').value = u.fullName || '';
  document.getElementById('uf_password').value = '';
  document.getElementById('uf_email').value = u.email || '';
  document.getElementById('uf_phone').value = u.phone || '';
  document.getElementById('uf_role').value = u.role || 'user';
  document.getElementById('uf_status').value = u.status || 'active';
  populateDeptSelect(u.departmentId?._id || u.departmentId || '');
  applySelfUserFormGuards(id, u.role || 'user');
  document.getElementById('userFormWrap').style.display = 'block';
  document.getElementById('userFormWrap').scrollIntoView({ behavior: 'smooth' });
}

function closeUserForm() {
  document.getElementById('userFormWrap').style.display = 'none';
  editingUserId = null;
  resetUserFormGuards();
}

async function saveUser(event) {
  event.preventDefault();
  const id = document.getElementById('editUserId').value;
  const body = {
    username: document.getElementById('uf_username').value.trim(),
    fullName: document.getElementById('uf_fullName').value.trim(),
    email: document.getElementById('uf_email').value.trim() || undefined,
    phone: document.getElementById('uf_phone').value.trim() || undefined,
    role: document.getElementById('uf_role').value,
    status: document.getElementById('uf_status').value,
    departmentId: document.getElementById('uf_dept').value || null,
  };
  if (id && String(id) === String(currentUserId)) {
    body.status = 'active';
  }
  const pwd = document.getElementById('uf_password').value;
  if (pwd) body.password = pwd;
  const data = id
    ? await api(`/api/admin/users/${id}`, { method: 'PUT', body: JSON.stringify(body) })
    : await api('/api/admin/users', { method: 'POST', body: JSON.stringify(body) });
  if (data.success) {
    closeUserForm();
    loadUsers();
    if (data.superToken) await showSuperToken(data.superToken);
    else notify(data.message || 'کاربر ذخیره شد.');
  }
  else notify(data.message || 'خطا در ذخیره', 'error');
}

async function deleteUser(id) {
  const u = usersMap.get(String(id));
  const name = u?.fullName || id;
  if (!(await confirmAction({
    title: 'حذف کاربر؟',
    text: `کاربر «${name}» حذف می‌شود.`,
    confirmText: 'حذف کاربر',
    icon: 'warning',
  }))) return;
  const data = await api(`/api/admin/users/${id}`, { method: 'DELETE' });
  if (data.success) { loadUsers(); notify(data.message || 'کاربر حذف شد.'); } else notify(data.message || 'خطا در حذف', 'error');
}

/* ===== DEPARTMENTS MANAGEMENT ===== */
const deptsMap = new Map();

async function loadDepts() {
  const data = await api('/api/admin/departments');
  const depts = data.success ? data.data : [];
  deptsMap.clear();
  depts.forEach(d => deptsMap.set(String(d._id), d));
  document.getElementById('deptsTableWrap').innerHTML = `
    <table class="table">
      <thead><tr><th>نام واحد</th><th>تعداد کاربران</th><th>عملیات</th></tr></thead>
      <tbody>${depts.map(d => `
        <tr>
          <td style="font-weight:700">${esc(d.name)}</td>
          <td>${d.userCount || 0} نفر</td>
          <td style="white-space:nowrap">
            <button class="btn btn-outline btn-sm" onclick="openEditDept('${d._id}')"><i class="fas fa-edit"></i></button>
            <button class="btn btn-danger btn-sm" onclick="deleteDept('${d._id}')"><i class="fas fa-trash"></i></button>
          </td>
        </tr>`).join('') || '<tr><td colspan="3" style="text-align:center;color:var(--text-muted)">واحدی ثبت نشده</td></tr>'}
      </tbody>
    </table>`;
}

function openAddDept() {
  document.getElementById('deptFormTitle').textContent = 'افزودن واحد';
  document.getElementById('editDeptId').value = '';
  document.getElementById('df_name').value = '';
  document.getElementById('deptFormWrap').style.display = 'block';
  document.getElementById('df_name').focus();
}

function openEditDept(id) {
  const d = deptsMap.get(String(id));
  if (!d) return;
  document.getElementById('deptFormTitle').textContent = 'ویرایش واحد';
  document.getElementById('editDeptId').value = id;
  document.getElementById('df_name').value = d.name || '';
  document.getElementById('deptFormWrap').style.display = 'block';
  document.getElementById('df_name').focus();
}

function closeDeptForm() { document.getElementById('deptFormWrap').style.display = 'none'; }

async function saveDept(event) {
  event.preventDefault();
  const id = document.getElementById('editDeptId').value;
  const name = document.getElementById('df_name').value.trim();
  const data = id
    ? await api(`/api/admin/departments/${id}`, { method: 'PUT', body: JSON.stringify({ name }) })
    : await api('/api/admin/departments', { method: 'POST', body: JSON.stringify({ name }) });
  if (data.success) { closeDeptForm(); loadDepts(); notify(data.message || 'واحد ذخیره شد.'); }
  else notify(data.message || 'خطا در ذخیره', 'error');
}

async function deleteDept(id) {
  const d = deptsMap.get(String(id));
  const name = d?.name || id;
  if (!(await confirmAction({
    title: 'حذف واحد؟',
    text: `واحد «${name}» حذف می‌شود و کاربران آن بدون واحد می‌مانند.`,
    confirmText: 'حذف واحد',
    icon: 'warning',
  }))) return;
  const data = await api(`/api/admin/departments/${id}`, { method: 'DELETE' });
  if (data.success) { loadDepts(); notify(data.message || 'واحد حذف شد.'); } else notify(data.message || 'خطا در حذف', 'error');
}

/* ===== ANNOUNCEMENTS MANAGEMENT ===== */
const announcementsMap = new Map();

function toggleAnnouncementDepts() {
  const audience = document.getElementById('ann_audience').value;
  document.getElementById('ann_depts_wrap').style.display = audience === 'department' ? 'block' : 'none';
}

async function ensureAnnouncementDeptOptions(selectedIds = []) {
  if (!departments.length) {
    const deptData = await api('/api/admin/departments');
    departments = deptData.success ? deptData.data : [];
  }
  const selected = new Set((selectedIds || []).map(String));
  document.getElementById('ann_departments').innerHTML =
    departments.map(d => `<option value="${d._id}" ${selected.has(String(d._id)) ? 'selected' : ''}>${esc(d.name)}</option>`).join('');
}

function initAnnouncementDatepicker() {
  if (!window.jalaliDatepicker) return;
  jalaliDatepicker.startWatch({
    autoHide: true,
    time: false,
    separatorChars: { date: '/' },
  });
}

function openAddAnnouncement() {
  document.getElementById('editAnnouncementId').value = '';
  document.getElementById('announcementFormTitle').textContent = 'ثبت اطلاعیه';
  document.getElementById('ann_title').value = '';
  document.getElementById('ann_body').value = '';
  document.getElementById('ann_audience').value = 'all';
  document.getElementById('ann_active').value = '1';
  document.getElementById('ann_expires').value = '';
  toggleAnnouncementDepts();
  ensureAnnouncementDeptOptions();
  document.getElementById('announcementFormWrap').style.display = 'block';
  initAnnouncementDatepicker();
}

function closeAnnouncementForm() {
  document.getElementById('announcementFormWrap').style.display = 'none';
}

async function editAnnouncement(id) {
  const item = announcementsMap.get(String(id));
  if (!item) return;
  document.getElementById('editAnnouncementId').value = id;
  document.getElementById('announcementFormTitle').textContent = 'ویرایش اطلاعیه';
  document.getElementById('ann_title').value = item.title || '';
  document.getElementById('ann_body').value = item.body || '';
  document.getElementById('ann_audience').value = item.audience || 'all';
  document.getElementById('ann_active').value = item.isActive ? '1' : '0';
  document.getElementById('ann_expires').value = item.jalaliExpiresAt || '';
  toggleAnnouncementDepts();
  await ensureAnnouncementDeptOptions(item.departmentIds || []);
  document.getElementById('announcementFormWrap').style.display = 'block';
  initAnnouncementDatepicker();
}

async function saveAnnouncement(e) {
  e.preventDefault();
  const id = document.getElementById('editAnnouncementId').value;
  const audience = document.getElementById('ann_audience').value;
  const deptSelect = document.getElementById('ann_departments');
  const departmentIds = audience === 'department'
    ? Array.from(deptSelect.selectedOptions).map(o => o.value)
    : [];
  const expiresRaw = document.getElementById('ann_expires').value.trim();

  const payload = {
    title: document.getElementById('ann_title').value.trim(),
    body: document.getElementById('ann_body').value.trim(),
    audience,
    departmentIds,
    isActive: document.getElementById('ann_active').value === '1',
    jalaliExpiresAt: expiresRaw || null,
  };

  const data = id
    ? await api(`/api/admin/announcements/${id}`, { method: 'PUT', body: JSON.stringify(payload) })
    : await api('/api/admin/announcements', { method: 'POST', body: JSON.stringify(payload) });

  if (data.success) {
    closeAnnouncementForm();
    loadAnnouncementsAdmin();
    notify(data.message || 'اطلاعیه ذخیره شد.');
  } else {
    notify(data.message || 'خطا در ذخیره', 'error');
  }
}

async function deleteAnnouncement(id) {
  const item = announcementsMap.get(String(id));
  if (!(await confirmAction({
    title: 'حذف اطلاعیه؟',
    text: item ? `«${item.title}» حذف می‌شود.` : 'این اطلاعیه حذف می‌شود.',
    confirmText: 'حذف',
    icon: 'warning',
  }))) return;

  const data = await api(`/api/admin/announcements/${id}`, { method: 'DELETE' });
  if (data.success) {
    loadAnnouncementsAdmin();
    notify(data.message || 'اطلاعیه حذف شد.');
  } else {
    notify(data.message || 'خطا در حذف', 'error');
  }
}

async function loadAnnouncementsAdmin() {
  const [annData, deptData] = await Promise.all([
    api('/api/admin/announcements'),
    api('/api/admin/departments'),
  ]);
  const items = annData.success ? annData.data : [];
  departments = deptData.success ? deptData.data : [];
  announcementsMap.clear();
  items.forEach(item => announcementsMap.set(String(item._id), item));

  document.getElementById('announcementsTableWrap').innerHTML = `
    <table class="table">
      <thead>
        <tr>
          <th>عنوان</th>
          <th>مخاطب</th>
          <th>وضعیت</th>
          <th>انقضا</th>
          <th>تاریخ</th>
          <th>عملیات</th>
        </tr>
      </thead>
      <tbody>${items.map(item => `
        <tr>
          <td style="font-weight:800;max-width:260px">${esc(item.title)}</td>
          <td>${item.audience === 'all'
            ? '<span class="badge badge-primary">همه کاربران</span>'
            : `<span class="badge badge-warning">${esc((item.departments || []).map(d => d.name).join('، ') || 'واحد')}</span>`}</td>
          <td>${item.isActive
            ? '<span class="badge badge-success">فعال</span>'
            : '<span class="badge badge-gray">غیرفعال</span>'}</td>
          <td>${item.jalaliExpiresAt ? esc(item.jalaliExpiresAt) : '—'}</td>
          <td>${new Date(item.createdAt).toLocaleString('fa-IR')}</td>
          <td style="display:flex;gap:6px">
            <button class="btn btn-outline btn-sm" onclick="editAnnouncement('${item._id}')"><i class="fas fa-pen"></i></button>
            <button class="btn btn-danger btn-sm" onclick="deleteAnnouncement('${item._id}')"><i class="fas fa-trash"></i></button>
          </td>
        </tr>
      `).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text-muted)">اطلاعیه‌ای ثبت نشده است</td></tr>'}</tbody>
    </table>`;
}

