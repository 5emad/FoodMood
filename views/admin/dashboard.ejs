function switchSubTab(tab) {
  currentSubTab = tab;
  document.querySelectorAll('.sub-tab-btn').forEach(b => b.classList.toggle('active', b.dataset.sub === tab));
  document.querySelectorAll('.sub-pane').forEach(p => p.classList.remove('active'));
