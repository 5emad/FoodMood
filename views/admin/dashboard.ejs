const persianMonthNames = ['فروردین','اردیبهشت','خرداد','تیر','مرداد','شهریور','مهر','آبان','آذر','دی','بهمن','اسفند'];
const expandedWeekNodes = new Set();

function jalaliYearMonth(dateValue) {
  const parts = new Intl.DateTimeFormat('en-US-u-ca-persian', { year: 'numeric', month: 'numeric' })
    .formatToParts(new Date(dateValue));
  const pick = (type) => Number((parts.find(p => p.type === type) || {}).value || 0);
  return { year: pick('year'), month: pick('month') };
}

function renderWeekCard(w) {
  return `
    <div class="week-card ${w.isActive ? 'is-active' : ''}" id="wcard-${w._id}">
      <div class="week-card-head">
        <div class="week-card-meta">
          <span class="week-card-name">${esc(w.name || 'هفته')}</span>
          <span class="week-card-date">(${esc(w.jalaliStart)} تا ${esc(w.jalaliEnd)})</span>
          ${w.isActive ? '<span class="badge badge-success"><i class="fas fa-circle" style="font-size:.5rem"></i> فعال</span>' : ''}
        </div>
        <div class="week-card-actions">
          <button class="btn btn-outline btn-sm" onclick="toggleWeekEditor('${w._id}')">
            <i class="fas fa-utensils"></i> مدیریت غذاها
          </button>
          ${!w.isActive ? `<button class="btn btn-success btn-sm" onclick="activateWeek('${w._id}')">
            <i class="fas fa-check-circle"></i> فعال کردن
          </button>` : ''}
          <button class="btn btn-danger btn-sm" onclick="deleteWeek('${w._id}')">
            <i class="fas fa-trash-alt"></i>
          </button>
        </div>
      </div>
      <div class="week-menu-editor" id="weditor-${w._id}">
        <div class="day-checkboxes" id="wdays-${w._id}"><div style="text-align:center;padding:20px"><div class="spinner"></div></div></div>
        <div style="text-align:left;margin-top:16px">
          <button class="btn btn-primary" onclick="saveWeekMenu('${w._id}')">
            <i class="fas fa-save"></i> ذخیره تغییرات منو
          </button>
        </div>
      </div>
    </div>`;
}

function renderWeeksManager() {
  const wrap = document.getElementById('weeksListWrap');
  if (!weeks.length) {
    wrap.innerHTML = `<div class="empty-state"><i class="fas fa-calendar-times"></i><p>هیچ هفته‌ای تعریف نشده است.</p></div>`;
    return;
  }

  // Build the year -> month -> weeks tree (grouped by the week's start date)
  const tree = new Map();
  for (const w of weeks) {
    const { year, month } = jalaliYearMonth(w.startDate);
    if (!tree.has(year)) tree.set(year, new Map());
    const months = tree.get(year);
    if (!months.has(month)) months.set(month, []);
    months.get(month).push(w);
  }

  // Default expansion: the year/month of the active week (or today's month)
  if (!expandedWeekNodes.size) {
    const anchor = weeks.find(w => w.isActive)?.startDate || new Date();
    const { year, month } = jalaliYearMonth(anchor);
    expandedWeekNodes.add(`y${year}`);
    expandedWeekNodes.add(`y${year}m${month}`);
  }

  const years = [...tree.keys()].sort((a, b) => b - a);
  wrap.innerHTML = `<div class="week-tree">${years.map(year => {
    const months = tree.get(year);
    const yearKey = `y${year}`;
    const yearOpen = expandedWeekNodes.has(yearKey);
    const yearCount = [...months.values()].reduce((sum, list) => sum + list.length, 0);
    const monthKeys = [...months.keys()].sort((a, b) => a - b);
    return `
    <div class="tree-year ${yearOpen ? 'open' : ''}" id="node-${yearKey}">
      <button type="button" class="tree-node-head tree-year-head" onclick="toggleWeekNode('${yearKey}')">
        <i class="fas fa-chevron-left tree-arrow"></i>
        <i class="fas fa-calendar"></i>
        <span>سال ${year.toLocaleString('fa-IR', { useGrouping: false })}</span>
        <span class="tree-count">${yearCount.toLocaleString('fa-IR')} هفته</span>
      </button>
      <div class="tree-children">
        ${monthKeys.map(month => {
          const monthKey = `y${year}m${month}`;
          const monthOpen = expandedWeekNodes.has(monthKey);
          const list = months.get(month).slice().sort((a, b) => new Date(a.startDate) - new Date(b.startDate));
          const hasActive = list.some(w => w.isActive);
          return `
          <div class="tree-month ${monthOpen ? 'open' : ''}" id="node-${monthKey}">
            <button type="button" class="tree-node-head tree-month-head" onclick="toggleWeekNode('${monthKey}')">
              <i class="fas fa-chevron-left tree-arrow"></i>
              <i class="far fa-calendar-alt"></i>
              <span>${persianMonthNames[month - 1] || ''}</span>
              <span class="tree-count">${list.length.toLocaleString('fa-IR')} هفته</span>
              ${hasActive ? '<span class="badge badge-success">هفته فعال</span>' : ''}
            </button>
            <div class="tree-children tree-weeks">
              ${list.map(renderWeekCard).join('')}
            </div>
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('')}</div>`;
}

function toggleWeekNode(key) {
  const node = document.getElementById(`node-${key}`);
  if (!node) return;
  if (expandedWeekNodes.has(key)) {
    expandedWeekNodes.delete(key);
    node.classList.remove('open');
  } else {
    expandedWeekNodes.add(key);
    node.classList.add('open');
  }
}

function toggleWeekEditor(weekId) {
  const editor = document.getElementById(`weditor-${weekId}`);
  if (editor.style.display === 'block') {
    editor.style.display = 'none';
  } else {
    editor.style.display = 'block';
    loadWeekDays(weekId);
  }
}

async function loadWeekDays(weekId) {
  const container = document.getElementById(`wdays-${weekId}`);
  const data = await api(`/api/menu/weeks/${encodeURIComponent(weekId)}`);
  if (!data.success || !data.data?.days) {
    container.innerHTML = '<div class="empty-state"><p>اطلاعات روزها یافت نشد.</p></div>'; return;
  }
  container.innerHTML = data.data.days.map(day => {
    const existingMap = {};
    day.items.forEach(item => { existingMap[String(item.foodId?._id || item.foodId)] = String(item._id); });
    return `<div class="day-box">
      <div class="day-box-head">${day.dayId?.name || ''} — ${jdate(day.date)}</div>
      <div class="day-box-body" data-daily-menu-id="${day._id}">
        ${foods.map(f => {
          const fid = String(f._id);
          const mid = existingMap[fid] || '';
          return `<label class="food-check-label">
            <input type="checkbox" value="${fid}" data-mid="${mid}" ${mid ? 'checked' : ''}> ${esc(f.name)}
          </label>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
}

async function saveWeekMenu(weekId) {
  const editor = document.getElementById(`weditor-${weekId}`);
  for (const box of editor.querySelectorAll('[data-daily-menu-id]')) {
    const dailyMenuId = box.dataset.dailyMenuId;
    for (const cb of box.querySelectorAll('input[type="checkbox"]')) {
      const foodId = cb.value;
      const mid = cb.dataset.mid;
      if (cb.checked && !mid) {
        await api('/api/admin/menu-items', { method: 'POST', body: JSON.stringify({ dailyMenuId, foodId, maxCapacity: appSettings?.defaultMenuItemCapacity ?? 50 }) });
      } else if (!cb.checked && mid) {
        await api(`/api/admin/menu-items/${mid}`, { method: 'DELETE' });
      }
    }
  }
  notify('منو با موفقیت ذخیره شد.');
  loadWeekDays(weekId);
}

async function activateWeek(weekId) {
  const data = await api(`/api/admin/weeks/${weekId}/activate`, { method: 'POST' });
  if (data.success) { await loadWeeksManager(); notify('هفته فعال شد.'); }
