NODE_ENV=production
PORT=3000
APP_URL=https://food.example.com
ALLOWED_ORIGINS=https://food.example.com

# Local MongoDB recommended for offline/air-gapped deployments
MONGODB_URI=mongodb://127.0.0.1:27017/food_ordering
MONGODB_TLS=false
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=8000

# Required in production — generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRE=8h
SESSION_IDLE_MINUTES=30
SESSION_MAX_HOURS=8
# Bind session to browser User-Agent (set false only for debugging)
SESSION_BIND_UA=true
BACKUP_SECRET=replace-with-backup-encryption-secret
PASSWORD_PEPPER=replace-with-password-pepper
# رمزنگاری متن اطلاعیه‌ها در دیتابیس (AES-256-GCM)
ANNOUNCEMENT_ENCRYPTION_KEY=replace-with-announcement-encryption-key

# مسیر لاگ‌های سیستمی (روی لینوکس: /var/log/foodmood)
LOG_DIR=./logs

# فقط برای تست قطعی دیتابیس در محیط توسعه (هرگز در production فعال نکنید)
# ALLOW_SYSTEM_TEST=true

# LDAP (optional — internal AD server, not public internet)
# LDAP_URL=ldaps://dc.company.local:636
# LDAP_SECURITY=ldaps
# LDAP_BASE_DN=DC=company,DC=local
# LDAP_BIND_DN=CN=svc-food,DC=company,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_CA_CERT_PATH=/opt/food/certs/ldap-ca.pem
# LDAP_USER_FILTER=(sAMAccountName={{username}})
# LDAP_ENCRYPTION_KEY=optional-fallback-for-announcement-crypto
# LDAP_ALLOWED_HOSTS=dc.company.local
# LDAP_ALLOW_INSECURE=false
